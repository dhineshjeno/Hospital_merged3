# ─────────────────────────────────────────────────────────────────────────
# Hospital Management System — Auth backend environment
# Copy to .env and fill in real values. NEVER commit .env.
# validateEnv.js refuses to boot with missing or placeholder values.
# ─────────────────────────────────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development

# Database (Aiven PostgreSQL). Rotate the password before first deployment —
# the development credentials were exposed and must be considered burned.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require

# Aiven CA certificate for verified TLS (download from Aiven console → CA cert).
# NEVER set NODE_TLS_REJECT_UNAUTHORIZED=0 — validateEnv will refuse to boot.
# PG_CA_CERT_PATH=./certs/aiven-ca.pem

# JWT — MUST be the IDENTICAL value in the hosdb backend's .env
# (hosdb verifies tokens this service issues).
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_EXPIRY=30m
REFRESH_TOKEN_EXPIRY=7d

# Encryption for PII at rest (Aadhaar/PAN). 64 hex chars.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# BACK THIS UP OUTSIDE THE SERVER — if it is lost, encrypted data is lost.
ENCRYPTION_KEY=

# Account lockout (per-account, on top of per-IP rate limiting)
MAX_LOGIN_ATTEMPTS=5
LOGIN_WINDOW_MS=900000

# CORS allow-list: comma-separated browser origins.
# Dev: the Vite server. Prod: your real domain.
FRONTEND_URL=http://localhost:5173

# Logging
LOG_LEVEL=info
AUDIT_LOG_ENABLED=true
MASK_PII_IN_LOGS=true
